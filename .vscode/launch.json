{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Cortex Debug: ST-LINK",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "openocd",
      "executable": "${workspaceFolder}/build_out/main.elf",
      "device": "STM32C562RE",
      "interface": "swd",
      "svdFile": "${workspaceFolder}/STM32C562.svd",
      "configFiles": [
        "interface/stlink-dap.cfg",
        "${workspaceFolder}/stm32c562re.cfg"
      ],
      "openOCDPreConfigLaunchCommands": [
        "set CPUTAPID 0x6ba02477"
      ],
      "runToEntryPoint": "main",
      "preLaunchTask": "GCC: Debug Build"
    }
  ]
}