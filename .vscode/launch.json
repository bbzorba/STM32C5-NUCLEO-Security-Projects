{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Active App (from Makefile)",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "openocd",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "GCC: Build + Flash for Debug",
      "executable": "${workspaceFolder}/build_out/main.elf",
      "device": "${config:stm32.device}",
      "interface": "swd",
      "noFileLoad": true,
      "configFiles": [
        "interface/stlink.cfg",
        "${workspaceFolder}/${config:stm32.openocdCfg}"
      ],
      "openOCDPreConfigLaunchCommands": [
        "set CPUTAPID ${config:stm32.cpuTapId}"
      ],
      "gdbPath": "arm-none-eabi-gdb",
      "svdFile": "${workspaceFolder}/${config:stm32.svdFile}",
      "runToEntryPoint": "main",
      "showDevDebugOutput": "raw"
    }
  ]
}