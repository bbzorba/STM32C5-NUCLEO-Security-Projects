# Minimal OpenOCD script for STM32C562RE on NUCLEO board
set CPUTAPID 0x6ba02477

source [find interface/stlink.cfg]
source [find target/stm32l5x.cfg]

# Allow flashing even if examination fails
set hla_target_name cortex_m

init
reset halt
set flash_base 0x08000000
set flash_size 0x100000
flash write_image erase Drivers/GPIO/main.bin 0x08000000
reset
shutdown
